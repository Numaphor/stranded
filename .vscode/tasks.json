{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "make",
            "command": "make",
            "args": [
                "-j8"
            ],
            "type": "shell"
        },
        {
            "label": "make (debug)",
            "command": "make",
            "args": [
                "-j8",
                "USERFLAGS=-Og",
                "USERLDFLAGS="
            ],
            "type": "shell",
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "stop",
            "type": "shell",
            "command": "taskkill /im mGBA.exe /F"
        },
        {
            "label": "stop mGBA",
            "type": "shell",
            "command": "cmd.exe /c \"taskkill /im mGBA.exe /F\" 2>/dev/null || pkill -f mgba 2>/dev/null || true",
            "presentation": { "reveal": "silent" }
        },
        {
            "label": "mGBA: gdbserver",
            "type": "shell",
            "command": "bash",
            "args": ["${workspaceFolder}/scripts/launch_debug.sh", "gdb"],
            "isBackground": true,
            "problemMatcher": {
                "pattern": { "regexp": "^$" },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^Launching mGBA",
                    "endsPattern": "^mGBA GDB server ready"
                }
            },
            "presentation": { "reveal": "silent", "panel": "dedicated" }
        },
        {
            "label": "mGBA: cli debugger",
            "type": "shell",
            "command": "bash",
            "args": ["${workspaceFolder}/scripts/launch_debug.sh", "cli"],
            "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
        },
        {
            "label": "mGBA: verbose logging",
            "type": "shell",
            "command": "bash",
            "args": ["${workspaceFolder}/scripts/launch_debug.sh", "log"],
            "presentation": { "reveal": "always", "panel": "dedicated" }
        },
        {
            "label": "mGBA: with Lua script",
            "type": "shell",
            "command": "bash",
            "args": ["${workspaceFolder}/scripts/launch_debug.sh", "lua"],
            "isBackground": true,
            "problemMatcher": {
                "pattern": { "regexp": "^$" },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^Launching mGBA",
                    "endsPattern": "^mGBA ready"
                }
            },
            "presentation": { "reveal": "silent", "panel": "dedicated" }
        },
        {
            "label": "debug: build + launch mGBA gdbserver",
            "dependsOn": ["make"],
            "dependsOrder": "sequence",
            "type": "shell",
            "command": "bash",
            "args": ["${workspaceFolder}/scripts/launch_debug.sh", "gdb"],
            "isBackground": true,
            "problemMatcher": {
                "pattern": { "regexp": "^$" },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^Launching mGBA",
                    "endsPattern": "^mGBA GDB server ready"
                }
            },
            "presentation": { "reveal": "silent", "panel": "dedicated" }
        }
    ]
}